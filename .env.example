# Resend (https://resend.com) — required for the contact + newsletter forms.
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Where contact-form messages and signup notifications are delivered.
RESEND_TO=sam@example.com

# Sender. Until samnewellrealestate.com is verified in Resend, leave unset
# to use Resend's sandbox sender (onboarding@resend.dev).
# RESEND_FROM=Sam Newell <hello@samnewellrealestate.com>

# Optional: collect newsletter signups into a Resend Audience instead of
# notification emails. Create one at https://resend.com/audiences
# RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
