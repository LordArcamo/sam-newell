---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CtaBand from '../../components/CtaBand.astro';
import Newsletter from '../../components/Newsletter.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = post.data.date.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const words = post.body?.split(/\s+/).length ?? 0;
const readTime = Math.max(1, Math.round(words / 200));

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  author: { '@type': 'Person', name: 'Sam Newell', url: Astro.site?.toString() },
  publisher: { '@type': 'Person', name: 'Sam Newell' },
  mainEntityOfPage: new URL(`/blog/${post.id}/`, Astro.site).toString(),
};
---

<Base title={`${post.data.title} — Sam Newell`} description={post.data.description} ogImage={post.data.cover}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <article>
    <header class="post-hero grain">
      <div class="container post-hero-inner">
        <div class="post-meta" data-reveal>
          <a href="/blog/" class="post-back">← All posts</a>
          <span class="post-tag">{post.data.tag}</span>
          <time datetime={post.data.date.toISOString()}>{fmt}</time>
          <span>{readTime} min read</span>
        </div>
        <h1 class="display post-title" data-reveal>{post.data.title}</h1>
        <p class="post-desc" data-reveal>{post.data.description}</p>
      </div>
    </header>

    <div class="section post-body-wrap">
      <div class="container">
        {post.data.cover && (
          <figure class="post-cover" data-reveal>
            <img src={post.data.cover} alt={post.data.coverAlt ?? ''} width="1536" height="1152" loading="eager" />
          </figure>
        )}
        <div class="prose">
          <Content />
        </div>
      </div>
    </div>
  </article>

  <CtaBand
    title="Read enough?"
    em="Let’s talk."
    copy="Every post ends the same way a good deal starts — with a straight conversation."
  />
  <Newsletter />
</Base>

<style>
  .post-hero {
    background:
      radial-gradient(60rem 40rem at 90% -20%, rgba(90, 90, 90, 0.35), transparent 60%),
      linear-gradient(180deg, var(--ink) 0%, var(--ink-2) 100%);
    color: var(--cream);
    padding-block: clamp(8.5rem, 14vw, 11rem) clamp(7rem, 11vw, 9rem);
    position: relative;
    overflow: clip;
  }

  .post-hero-inner {
    max-width: 46rem;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.1rem;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cream-60);
  }

  .post-back {
    color: var(--cream);
    text-decoration: none;
  }

  .post-back:hover {
    color: var(--brass-bright);
  }

  .post-tag {
    border: 1px solid var(--cream-20);
    border-radius: 999px;
    padding: 0.3rem 0.85rem;
    color: var(--cream);
  }

  .post-title {
    font-size: var(--step-3);
    margin-block: 1.4rem 1.1rem;
  }

  .post-desc {
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--cream-60);
  }

  .post-body-wrap {
    background: var(--cream);
  }

  .post-cover {
    max-width: 46rem;
    margin: -6rem auto 3rem;
    position: relative;
    z-index: 2;
    border-radius: 1.25rem;
    overflow: clip;
    aspect-ratio: 16 / 9;
    box-shadow: 0 40px 70px -30px rgba(19, 19, 19, 0.45);
  }

  .post-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .prose {
    max-width: 42rem;
    margin-inline: auto;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-1);
    margin: 2.25rem 0 0.8rem;
    line-height: 1.3;
  }

  .prose :global(p) {
    margin-bottom: 1.2rem;
    color: rgba(19, 19, 19, 0.78);
    line-height: 1.75;
  }

  .prose :global(ol),
  .prose :global(ul) {
    margin: 0 0 1.2rem 1.4rem;
    color: rgba(19, 19, 19, 0.78);
    line-height: 1.75;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(a) {
    color: var(--ink);
    font-weight: 600;
    text-decoration-color: var(--brass);
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--ink);
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid rgba(19, 19, 19, 0.12);
    margin: 2.25rem 0;
  }

  .prose :global(strong) {
    font-weight: 700;
  }
</style>
